{
  "regions": ["hnd1"],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/_/backend/api/:match*"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "framework": "nextjs"
    }
  }
}
